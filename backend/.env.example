# ── Groq LLM Configuration ───────────────────────────────────────────────────
# Retrieve your API key from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024

# ── Database Configuration ────────────────────────────────────────────────────
# PostgreSQL connection URL format: postgresql://username:password@host:port/database_name
# For SQLite local development fallback, you can use: sqlite:///./dispute_resolution.db
DATABASE_URL=postgresql://postgres:password@localhost:5432/bfsi_dispute_db
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=dispute_cases

# ── OCR Configuration ─────────────────────────────────────────────────────────
# Path to Tesseract OCR executable (e.g. D:\Tesseract\tesseract.exe on Windows or /usr/bin/tesseract on Linux)
TESSERACT_CMD=tesseract

# ── Server Configuration ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
# Comma-separated list of allowed frontend origins (use * for all origins in production)
CORS_ORIGINS=*

# ── App Metadata ──────────────────────────────────────────────────────────────
APP_NAME=BFSI Dispute Resolution Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ── Security & Authentication ─────────────────────────────────────────────────
# Generate a secure key in production (e.g. openssl rand -hex 32)
SECRET_KEY=change-this-in-production-to-a-secure-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Customer Communication Agent (Agent 6 — CCA) ──────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=notifications@yourbank.com
